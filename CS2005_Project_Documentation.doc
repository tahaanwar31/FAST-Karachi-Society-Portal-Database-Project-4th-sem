<!-- ==================== 7. API ENDPOINTS ==================== -->
<h2>7. API Endpoints (48 total)</h2>

<h3>Authentication (3)</h3>
<table>
  <tr><th>Method</th><th>Endpoint</th><th>Auth</th><th>Description</th></tr>
  <tr><td>POST</td><td>/api/auth/login</td><td>No</td><td>Login with email + password, sets HTTP-only cookie</td></tr>
  <tr><td>POST</td><td>/api/auth/logout</td><td>No</td><td>Clears session cookie</td></tr>
  <tr><td>GET</td><td>/api/auth/me</td><td>Cookie</td><td>Returns current user or null</td></tr>
</table>

<h3>Public Browsing (4)</h3>
<table>
  <tr><th>Method</th><th>Endpoint</th><th>Auth</th><th>Description</th></tr>
  <tr><td>GET</td><td>/api/events</td><td>No</td><td>All published events with participant count</td></tr>
  <tr><td>GET</td><td>/api/events/:id</td><td>No</td><td>Single event details</td></tr>
  <tr><td>GET</td><td>/api/societies</td><td>No</td><td>All societies with head/co-head names</td></tr>
  <tr><td>GET</td><td>/api/venues</td><td>No</td><td>All venues</td></tr>
</table>

<h3>Student Actions (4)</h3>
<table>
  <tr><th>Method</th><th>Endpoint</th><th>Auth</th><th>Description</th></tr>
  <tr><td>POST</td><td>/api/events/:id/register</td><td>Yes</td><td>Register for event (checks capacity, duplicates)</td></tr>
  <tr><td>POST</td><td>/api/events/:id/unregister</td><td>Yes</td><td>Cancel registration</td></tr>
  <tr><td>GET</td><td>/api/registrations/my</td><td>Yes</td><td>Get user's registrations (REGISTERED + ATTENDED)</td></tr>
  <tr><td>GET</td><td>/api/events/:id/participants</td><td>Yes</td><td>List participants for an event</td></tr>
</table>

<h3>Feedback (3)</h3>
<table>
  <tr><th>Method</th><th>Endpoint</th><th>Auth</th><th>Description</th></tr>
  <tr><td>POST</td><td>/api/events/:id/feedback</td><td>Yes</td><td>Submit feedback (attended events only, rating 1&ndash;5)</td></tr>
  <tr><td>GET</td><td>/api/events/:id/feedback</td><td>Yes</td><td>Get all feedback for an event</td></tr>
  <tr><td>GET</td><td>/api/head/feedback</td><td>Head</td><td>Get all feedback for society head's events</td></tr>
</table>

<h3>Attendance (2)</h3>
<table>
  <tr><th>Method</th><th>Endpoint</th><th>Auth</th><th>Description</th></tr>
  <tr><td>POST</td><td>/api/head/mark-attendance</td><td>Head</td><td>Mark selected users as ATTENDED</td></tr>
  <tr><td>GET</td><td>/api/events/:id/attendance</td><td>Yes</td><td>Get participants with attendance status</td></tr>
</table>

<h3>Society Head &mdash; Events &amp; Requests (5)</h3>
<table>
  <tr><th>Method</th><th>Endpoint</th><th>Auth</th><th>Description</th></tr>
  <tr><td>GET</td><td>/api/head/my-events</td><td>Head</td><td>Get society's events with registration count</td></tr>
  <tr><td>POST</td><td>/api/head/create-event</td><td>Head</td><td>Create event (validates venue availability + capacity)</td></tr>
  <tr><td>POST</td><td>/api/head/event-request</td><td>Head</td><td>Submit UPDATE or DELETE request for admin review</td></tr>
  <tr><td>GET</td><td>/api/head/notifications</td><td>Head</td><td>Get resolved request notifications</td></tr>
  <tr><td>GET</td><td>/api/head/my-event-requests</td><td>Head</td><td>Get all own requests (all statuses)</td></tr>
</table>

<h3>Admin &mdash; Events (5)</h3>
<table>
  <tr><th>Method</th><th>Endpoint</th><th>Auth</th><th>Description</th></tr>
  <tr><td>GET</td><td>/api/admin/pending-events</td><td>Admin</td><td>Get all PENDING events</td></tr>
  <tr><td>POST</td><td>/api/admin/approve-event/:id</td><td>Admin</td><td>Approve event (set PUBLISHED)</td></tr>
  <tr><td>POST</td><td>/api/admin/reject-event/:id</td><td>Admin</td><td>Reject event (set CANCELLED)</td></tr>
  <tr><td>GET</td><td>/api/admin/event-requests</td><td>Admin</td><td>Get pending event change requests</td></tr>
  <tr><td>POST</td><td>/api/admin/approve-event-request/:id</td><td>Admin</td><td>Approve request (applies proposed changes)</td></tr>
  <tr><td>POST</td><td>/api/admin/reject-event-request/:id</td><td>Admin</td><td>Reject request with admin_reason</td></tr>
</table>

<h3>Admin &mdash; Societies &amp; Venues (7)</h3>
<table>
  <tr><th>Method</th><th>Endpoint</th><th>Auth</th><th>Description</th></tr>
  <tr><td>POST</td><td>/api/admin/societies</td><td>Admin</td><td>Create society (auto APPROVED)</td></tr>
  <tr><td>PATCH</td><td>/api/admin/societies/:id/roles</td><td>Admin</td><td>Assign head_id / co_head_id</td></tr>
  <tr><td>DELETE</td><td>/api/admin/societies/:id</td><td>Admin</td><td>Delete society</td></tr>
  <tr><td>PATCH</td><td>/api/admin/venues/:id</td><td>Admin</td><td>Toggle venue availability (YES/NO)</td></tr>
  <tr><td>POST</td><td>/api/admin/venues</td><td>Admin</td><td>Add new venue</td></tr>
  <tr><td>DELETE</td><td>/api/admin/venues/:id</td><td>Admin</td><td>Delete venue (only if no events assigned)</td></tr>
  <tr><td>GET</td><td>/api/admin/users</td><td>Admin</td><td>Get all users</td></tr>
</table>

<h3>Admin &mdash; Role Registries (12)</h3>
<table>
  <tr><th>Method</th><th>Endpoint</th><th>Auth</th><th>Description</th></tr>
  <tr><td>GET/POST/DELETE</td><td>/api/admin/admins[/:id]</td><td>Admin</td><td>CRUD for admin records</td></tr>
  <tr><td>GET/POST/DELETE</td><td>/api/admin/heads[/:id]</td><td>Admin</td><td>CRUD for head records</td></tr>
  <tr><td>GET/POST/DELETE</td><td>/api/admin/co-heads[/:id]</td><td>Admin</td><td>CRUD for co-head records</td></tr>
  <tr><td>GET/POST/DELETE</td><td>/api/admin/student-members[/:id]</td><td>Admin</td><td>CRUD for student member records</td></tr>
</table>

<h3>Admin &mdash; System (4)</h3>
<table>
  <tr><th>Method</th><th>Endpoint</th><th>Auth</th><th>Description</th></tr>
  <tr><td>GET</td><td>/api/admin/stats</td><td>Admin</td><td>Row counts for all tables</td></tr>
  <tr><td>GET</td><td>/api/admin/system/inspect</td><td>Admin</td><td>Full database dump (every table, every row)</td></tr>
  <tr><td>POST</td><td>/api/admin/query</td><td>Admin</td><td>Execute raw SQL query</td></tr>
</table>

